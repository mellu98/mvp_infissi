# ============================================================
# MVP Infissi — Environment Variables (example)
# Copy to .env.local for development.
# ============================================================

# --- App ---
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mvp_infissi?schema=public

# --- Auth (NextAuth v5) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-random-32-bytes
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# --- Storage ---
# Provider: local | appwrite
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=./uploads

# --- AI Provider ---
# Provider: mock | anthropic | openai
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Appwrite (optional) ---
APPWRITE_ENABLED=false
NEXT_PUBLIC_APPWRITE_ENDPOINT=
NEXT_PUBLIC_APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=
APPWRITE_BUCKET_ID=

# --- SMTP (optional, not used in MVP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@linkinfissi.it

# --- GlitchTip / Sentry ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Seed control ---
# Set to "true" to allow seeding in production (default: blocked)
ALLOW_PROD_SEED=false
