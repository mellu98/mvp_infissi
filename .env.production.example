# ============================================================
# MVP Infissi — Production Environment (example for Coolify)
# Set these in Coolify's "Environment Variables" panel.
# ============================================================

APP_URL=https://app.linkinfissi.it
NEXT_PUBLIC_APP_URL=https://app.linkinfissi.it
NODE_ENV=production
PORT=3000

# DB — either Coolify-managed PostgreSQL or external
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/mvp_infissi?schema=public&sslmode=require

# Auth
NEXTAUTH_SECRET=generate-strong-secret-via-openssl-rand-base64-32
NEXTAUTH_URL=https://app.linkinfissi.it
AUTH_TRUST_HOST=true

# Storage — local with persistent Docker volume
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=/app/uploads

# AI
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Appwrite (optional)
APPWRITE_ENABLED=false
NEXT_PUBLIC_APPWRITE_ENDPOINT=
NEXT_PUBLIC_APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=
APPWRITE_BUCKET_ID=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@linkinfissi.it

# Seed
ALLOW_PROD_SEED=false
